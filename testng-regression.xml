<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Regression" verbose="1" parallel="classes" thread-count="3">
    <listeners>
        <listener class-name="com.example.weather.tests.FlowExecutionListener"/>
    </listeners>
    <parameter name="suite.type" value="regression"/>
    <test name="City-Regression">
        <classes>
            <class name="com.example.weather.tests.regression.CityRegressionTests"/>
        </classes>
    </test>
    <test name="Weather-Regression">
        <classes>
            <class name="com.example.weather.tests.regression.WeatherRegressionTests"/>
        </classes>
    </test>
    <test name="Alert-Regression">
        <classes>
            <class name="com.example.weather.tests.regression.AlertRegressionTests"/>
        </classes>
    </test>
</suite>
